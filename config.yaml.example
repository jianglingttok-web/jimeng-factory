# 即梦内容工厂 — 配置文件模板
# 复制为 config.yaml 后按需修改

web:
  host: "127.0.0.1"
  port: 8001
  cors_origins:
    - "http://localhost:5173"
    - "http://localhost:5174"
    - "http://127.0.0.1:5173"
    - "http://127.0.0.1:8001"

paths:
  data_dir: "data/products"       # 产品数据目录
  output_dir: "outputs"           # 视频输出目录
  database_path: "runtime/app.db" # SQLite 数据库路径

video:
  default_duration_seconds: 10
  max_images: 3
  max_retries: 2                  # 提交/下载失败自动重试次数
  task_timeout_seconds: 1800      # 单任务超时（秒）

  jimeng_defaults:
    mode: "视频生成"
    model: "Seedance 2.0 Fast"
    reference_type: "全能参考"
    aspect_ratio: "9:16"

providers:
  jimeng:
    enabled: true
    base_url: "https://jimeng.jianying.com/ai-tool/home?type=video&workspace=0"

    # ★★★ 多空间浏览器路径 — 根据实际安装位置修改 ★★★
    # ★ 重要：路径请用正斜杠 /（不要用反斜杠 \）
    # ★ 错误: "C:\Users\xxx\多空间浏览器.exe"  ← 反斜杠会报错！
    # ★ 正确: C:/Users/xxx/多空间浏览器.exe     ← 正斜杠没问题
    space_data_dir: '%APPDATA%/mul-key-chrome/SpaceData'
    browser_executable_path: C:/Users/你的用户名/AppData/Local/Programs/mul-key-chrome/mul-key-chrome.exe

    cdp_url: "http://127.0.0.1:9222"  # CDP 调试端口
    web_port: 3000                    # 多空间浏览器控制端口
    default_concurrency: 10           # 每账号最大并发任务数
    accounts: []                      # 启动后自动发现，无需手填
